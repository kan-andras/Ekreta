<Window
    x:Class="Ekreta.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Ekreta"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary Source="Resourches/ListItem.xaml" />
    </Window.Resources>
    <DockPanel Background="CornflowerBlue">
        <StackPanel Height="30" DockPanel.Dock="Top">
            <TextBlock
                FontWeight="Bold"
                Foreground="White"
                Text="eKréta Adminisztrátori felület"
                TextAlignment="Center" />
        </StackPanel>
        <StackPanel
            Width="200"
            Background="DeepSkyBlue"
            DockPanel.Dock="Left">
            <ListView>
                <ListViewItem
                    x:Name="diakMenu"
                    MouseLeftButtonUp="diakMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}">
                    Diákok
                </ListViewItem>
                <ListViewItem
                    x:Name="tanarMenu"
                    MouseLeftButtonUp="tanarMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}">
                    Tanárok
                </ListViewItem>
                <ListViewItem
                    x:Name="osztalyMenu"
                    MouseLeftButtonUp="osztalyMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}">
                    Osztályok
                </ListViewItem>
                <ListViewItem
                    x:Name="termekMenu"
                    MouseLeftButtonUp="termekMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}">
                    Termek
                </ListViewItem>
                <ListViewItem
                    x:Name="felhasznalokMenu"
                    MouseLeftButtonUp="felhasznalokMenu_MouseLeftButtonUp"
                    Style="{StaticResource ResourceKey=ListItemStyle}">
                    Felhasználók
                </ListViewItem>
                <ListViewItem
                    x:Name="kilepesMenu"
                    Background="red"
                    Foreground="White"
                    MouseLeftButtonUp="kilepesMenu_MouseLeftButtonUp">
                    Bezárás
                </ListViewItem>
            </ListView>
        </StackPanel>
        <StackPanel
            x:Name="feladatPanel"
            Background="Brown"
            DockPanel.Dock="Right" />
    </DockPanel>
</Window>
